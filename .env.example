# ── Required: AI providers used by the default adapters (packages/server/src/adapters/providers) ──
# Text/copywriting/storyboarding (default: Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Image generation/editing + multimodal QA/brand analysis (default: Google Gemini)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-pro

# Optional second image engine, auto-selected per format when set (default: OpenAI)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# ── Required: persistence (default adapter: Supabase — Postgres + Storage) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional server config ──
PORT=3001
# Comma-separated list of allowed CORS origins, or omit for "*"
CORS_ORIGIN=http://localhost:5173
# If set, every request (except PUBLIC_PATHS in src/index.ts) must send this
# value in the X-Api-Key header. Leave unset to disable the gate entirely.
DCO_API_SECRET=
# Point at your own folder of .ttf files instead of the bundled ones.
DCO_FONTS_DIR=
# tesseract.js language code for the anti-text OCR gate (default: spa)
DCO_OCR_LANG=spa

# ── Client (packages/client) ──
VITE_DCO_API_URL=http://localhost:3001
