# DCO Studio — this is a VERBATIM port of MUSE's DCO backend. Env var names
# match the original code exactly (see routes/dco.ts, services/supabase.ts).

# ── Required ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SUPABASE_URL=
# Any ONE of these three (checked in this order — same fallback as the original):
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── Required for the GPT-image-2 path (imageProvider=gpt in /generate, and /recreate-formats) ──
OPENAI_API_KEY=

# ── Optional ──
PORT=3001
# Comma-separated list of allowed CORS origins, or omit for "*".
# NOTE: the original server.ts hardcoded MUSE's own domains here — this repo
# makes it configurable instead, since your platform's origin is not MUSE's.
CORS_ORIGIN=http://localhost:5173
# If set, every /api/dco/* request (except /api/dco/template) must send this
# value in the X-Muse-Key header — same behavior as the original. The ported
# DCOView.tsx frontend does NOT send this header (neither did the source), so
# if you set this you need to inject the header yourself (reverse proxy / edge).
API_SECRET=

# ── Client (packages/client) ──
# Same env var name DCOView.tsx reads directly (import.meta.env.VITE_API_URL).
VITE_API_URL=http://localhost:3001
